# Supabase Configuration (Required for database connectivity)
# 
# Get these values from Supabase dashboard:
# 1. Go to https://supabase.com
# 2. Log in to your project
# 3. Click "Settings" → "API"
# 4. Copy the Project URL and Anon Key
#
# For menu items to display:
# - Insert menu items into the database via Supabase dashboard
# - OR configure these credentials and use the Admin panel

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Example Supabase setup (do this first in Supabase Console):
#
# 1. Go to SQL Editor
# 2. Paste contents of supabase/schema.sql
# 3. Execute the SQL
# 4. Create 3 test staff accounts:
#    - Admin: admin@esgfood.com / Admin@123456
#    - Service Desk: desk@esgfood.com / Desk@123456
#    - Kitchen: kitchen@esgfood.com / Kitchen@123456
# 5. Get the Project URL and Anon Key from Settings > API
# 6. Add them to this .env file (copy from .env.example)
# 7. Add menu items:
#    - Go to SQL Editor
#    - Run INSERT statements:
#
#    INSERT INTO menu_items (name, price, category_id, available)
#    VALUES 
#      ('Coconut Rice Bowl', 15000, <lunch_category_id>, true),
#      ('Nyama Choma Plate', 25000, <lunch_category_id>, true),
#      ('Ginger Tea', 3000, <hot_drinks_category_id>, true);
#
# Categories should already exist from schema.sql
